# Base URL of the site
# dev: http://localhost:3000
# prod: https://medent-jobs.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console verification ID 
NEXT_PUBLIC_GOOGLE_VERIFICATION_ID=

# Google Tag Manager container ID 
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# External job feed API URL
# JOBS_API_URL=https://api.example.com/jobs

# Data source strategy: "local" (default) or "api"
# DATA_SOURCE=local